# ──────────────────────────────────────────────
# VPN Node Agent — example environment file
# Copy to .env and fill in real values before
# running docker compose up -d
# ──────────────────────────────────────────────

# Security — shared secret between Orchestrator and this Node Agent
AGENT_SECRET=<generate-strong-random-secret>

# 3x-ui panel
XUI_BASE_URL=http://127.0.0.1:2053
XUI_USERNAME=admin
XUI_PASSWORD=<your-xui-panel-password>
XUI_VLESS_INBOUND_ID=1        # ID of the VLESS Reality inbound in 3x-ui

# MTProto proxy (mtg)
MTG_CONFIG_PATH=/etc/mtg/config.toml
MTG_SERVER_IP=<YOUR_PUBLIC_IP>  # Public IP of this VPN server
MTG_PORT=2443

# HTTP server
PORT=8080

# Logging: "json" for production, "console" for development
LOG_LEVEL=INFO
LOG_FORMAT=json
