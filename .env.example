# ──────────────────────────────────────────────
# VPN Node Agent — example environment file
# Copy to .env and fill in real values before
# running docker compose up -d
# ──────────────────────────────────────────────

# Security — shared secret between Orchestrator and this Node Agent
AGENT_SECRET=<generate-strong-random-secret>

# 3x-ui panel
# node-agent runs with network_mode: host, so it reaches 3x-ui via 127.0.0.1.
# Include the secret base path if the panel is configured with one.
# Default port:              http://127.0.0.1:2053
# Custom port + base path:   http://127.0.0.1:13371/fast_speed
XUI_BASE_URL=http://127.0.0.1:2053
XUI_USERNAME=admin
XUI_PASSWORD=<your-xui-panel-password>
XUI_VLESS_INBOUND_ID=1        # ID of the VLESS Reality inbound in 3x-ui

# MTProto proxy (mtg)
MTG_CONFIG_PATH=/etc/mtg/config.toml
MTG_SERVER_IP=<YOUR_PUBLIC_IP>  # Public IP of this VPN server
MTG_PORT=2443                   # Public port (host-side of docker port mapping, e.g. 2443->3128)

# HTTP server
PORT=8080

# Logging: "json" for production, "console" for development
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Deployment mode ─────────────────────────────────────────────────────────
# Scenario A — fresh server (full stack via docker compose up -d):
#   Leave MTG_CONFIG_HOST_PATH unset; scripts/init.sh generates config/mtg/config.toml
#
# Scenario B — server with existing 3x-ui + mtproto running separately:
#   Set MTG_CONFIG_HOST_PATH to the existing config.toml on the host.
#   Set XUI_BASE_URL to http://127.0.0.1:<port>/<base-path> (panel's actual address).
#   Run: docker compose up -d --no-deps --build node-agent  (skip 3x-ui/mtg)
#
# MTG_CONFIG_HOST_PATH=/etc/mtg/config.toml
